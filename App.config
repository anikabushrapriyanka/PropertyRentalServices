<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <add name="PropertyRentalDB"
         connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=PropertyRentalDB;Integrated Security=True;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="AppName" value="Property Rental Services"/>
    <add key="Version" value="1.0.0"/>
  </appSettings>
</configuration>
